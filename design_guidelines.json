{
  "theme": "Light",
  "archetype": "1 (Organic & Earthy) with Luxury Elements",
  "brand_name": "Nepal Trip",
  "colors": {
    "background": "#FAFAF8",
    "surface": "#FFFFFF",
    "primary": "#1C3144",
    "secondary": "#4A4A4A",
    "accent_1": "#DC143C",
    "accent_2": "#EAA015",
    "text_primary": "#1C3144",
    "text_secondary": "#4A4A4A",
    "border": "#E5E5E5"
  },
  "typography": {
    "heading_font": "Cormorant Garamond",
    "body_font": "Manrope",
    "rules": {
      "h1": "text-5xl sm:text-6xl+ tracking-tight font-light",
      "h2": "text-3xl sm:text-4xl tracking-tight",
      "h3": "text-2xl sm:text-3xl",
      "body": "text-base leading-relaxed",
      "overline": "uppercase text-sm tracking-[0.2em] font-bold"
    }
  },
  "layout_and_spacing": {
    "container_padding": "px-6 md:px-12 lg:px-24",
    "section_spacing": "py-24 lg:py-32",
    "bento_grid": "grid grid-cols-1 md:grid-cols-12 gap-8",
    "border_radius": "rounded-none md:rounded-sm"
  },
  "components": {
    "header": {
      "style": "Crystal Glass - backdrop-blur-xl bg-white/90 border-b border-border/40 z-50 sticky top-0",
      "links": ["Home", "About Us", "Packages", "Services", "Testimonials", "Contact Us"]
    },
    "hero": {
      "style": "Cinematic full-width slider with asymmetrical overlay bg-black/40. Left-aligned typography."
    },
    "buttons": {
      "primary": "bg-[#1C3144] text-white hover:bg-[#1C3144]/90 px-8 py-4 uppercase tracking-wider text-sm transition-colors",
      "accent": "bg-[#DC143C] text-white hover:bg-[#DC143C]/90 px-8 py-4 uppercase tracking-wider text-sm transition-colors"
    },
    "cards": {
      "services": "Cardless approach or 1px border with no shadow, sharp corners, hover:scale-[1.02] transition-transform duration-300",
      "packages": "Image-first cards with gradient overlay from bottom, text white."
    }
  },
